{
  "tasks": {
    "server": "deno run --no-prompt --allow-run --allow-read --allow-ffi --allow-net --allow-env=HOME,LIMA_ESCAPE_TOKENS server.ts",
    "client": "deno run --no-prompt --allow-net --allow-env=HOME,LIMA_ESCAPE_HOST,LIMA_ESCAPE_PORT,LIMA_ESCAPE_TOKEN --allow-read --allow-write main.ts"
  },
  "imports": {
    "@jlarky/gha-ts": "jsr:@jlarky/gha-ts@^0.2.1",
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "@std/yaml": "jsr:@std/yaml@^1.0.12"
  },
  "test": {
    "include": ["*_test.ts"]
  },
  "fmt": {
    "exclude": [".github/workflows/*.generated.yml"]
  },
  "lint": {
    "exclude": [".github/workflows/*.generated.yml"]
  }
}
